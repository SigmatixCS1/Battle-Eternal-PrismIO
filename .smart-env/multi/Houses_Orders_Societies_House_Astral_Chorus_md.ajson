fb-2215774b36c5_1.png","target":"csalchemsy_The_Lyceum_of_the_Astral_Chorus_on_the_Saint_Radia_0668bacf-c429-462b-b9fb-2215774b36c5_1.png","line":26,"embedded":true},{"title":"csalchemsy_The_Lyceum_of_the_Astral_Chorus_on_the_Saint_Radia_aaa5bda5-d1a7-49ae-bfaf-16db572de122_2.png","target":"csalchemsy_The_Lyceum_of_the_Astral_Chorus_on_the_Saint_Radia_aaa5bda5-d1a7-49ae-bfaf-16db572de122_2.png","line":28,"embedded":true},{"title":"csalchemsy_The_Lyceum_of_the_Astral_Chorus_on_the_Saint_Radia_aaa5bda5-d1a7-49ae-bfaf-16db572de122_3.png","target":"csalchemsy_The_Lyceum_of_the_Astral_Chorus_on_the_Saint_Radia_aaa5bda5-d1a7-49ae-bfaf-16db572de122_3.png","line":30,"embedded":true},{"title":"csalchemsy_The_Lyceum_of_the_Astral_Chorus_on_the_Saint_Radia_aaa5bda5-d1a7-49ae-bfaf-16db572de122_1.png","target":"csalchemsy_The_Lyceum_of_the_Astral_Chorus_on_the_Saint_Radia_aaa5bda5-d1a7-49ae-bfaf-16db572de122_1.png","line":32,"embedded":true},{"title":"csalchemsy_The_Lyceum_of_the_Astral_Chorus_on_the_Saint_Radia_fd35917b-d353-4951-9477-0fb66adfa269_2.png","target":"csalchemsy_The_Lyceum_of_the_Astral_Chorus_on_the_Saint_Radia_fd35917b-d353-4951-9477-0fb66adfa269_2.png","line":34,"embedded":true},{"title":"csalchemsy_The_Lyceum_of_the_Astral_Chorus_on_the_Saint_Radia_fd35917b-d353-4951-9477-0fb66adfa269_3.png","target":"csalchemsy_The_Lyceum_of_the_Astral_Chorus_on_the_Saint_Radia_fd35917b-d353-4951-9477-0fb66adfa269_3.png","line":36,"embedded":true},{"title":"csalchemsy_The_Lyceum_of_the_Astral_Chorus_on_the_Saint_Radia_fd35917b-d353-4951-9477-0fb66adfa269_1.png","target":"csalchemsy_The_Lyceum_of_the_Astral_Chorus_on_the_Saint_Radia_fd35917b-d353-4951-9477-0fb66adfa269_1.png","line":38,"embedded":true},{"title":"csalchemsy_The_Lyceum_of_the_Astral_Chorus_on_the_Saint_Radia_fd35917b-d353-4951-9477-0fb66adfa269_0.png\nThe **Astral Chorus** blends psychology, psychic empathy, and occult archetype studies into a school of astral science. They pioneer experiments into shared dreamwalking and archetypal resonance.  \n\n**Dormitory — The Lyceum**: circular chambers painted with murals of constellations and archetypal figures, doubling as meditation and dream-mapping spaces.  \n\n- **Occult Specialty:** *Empathic attunement* — members can bond willingly with beasts rather than bind them. This skill alone gives them disproportionate power.  \n- **Role in Academy:** Their empathetic research “softens” students, making them harder to indoctrinate. This puts them in Finch’s crosshairs.  \n- **Rivalry:** At odds with **Crimson Flame**, debating compassion vs domination as the true path to strength.  \n- **Uniform Accents:** Constellation-embroidered linings in ties, faint dream-halo around their crest when using gifts.  \n\n### Tools\n- [[DREAMLENS","target":"csalchemsy_The_Lyceum_of_the_Astral_Chorus_on_the_Saint_Radia_fd35917b-d353-4951-9477-0fb66adfa269_0.png\nThe **Astral Chorus** blends psychology, psychic empathy, and occult archetype studies into a school of astral science. They pioneer experiments into shared dreamwalking and archetypal resonance.  \n\n**Dormitory — The Lyceum**: circular chambers painted with murals of constellations and archetypal figures, doubling as meditation and dream-mapping spaces.  \n\n- **Occult Specialty:** *Empathic attunement* — members can bond willingly with beasts rather than bind them. This skill alone gives them disproportionate power.  \n- **Role in Academy:** Their empathetic research “softens” students, making them harder to indoctrinate. This puts them in Finch’s crosshairs.  \n- **Rivalry:** At odds with **Crimson Flame**, debating compassion vs domination as the true path to strength.  \n- **Uniform Accents:** Constellation-embroidered linings in ties, faint dream-halo around their crest when using gifts.  \n\n### Tools\n- [[DREAMLENS","line":40,"embedded":true},{"title":"AURORA_SIGIL","target":"AURORA_SIGIL","line":51},{"title":"Dreams_Oneiromancy_Arc","target":"Dreams_Oneiromancy_Arc","line":53}],"metadata":{"order_id":"astral-chorus","name":"The Astral Chorus","dorm":"The Lyceum","motto":"Mind is matter.","focus":"Jungian analysis, empathy studies, astral projection","specialization":"Oneiromancy, archetypal resonance, proto-telepathy","status":"mocked outwardly, feared secretly","signature_beasts":"Kitsune, Yatagarasu, Phoenix","rivalries":"Crimson Flame","tags":["#house","#order","#lore","#astral","#empathy"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1x2nyz0","at":1774633475776},"key":"Houses_Orders_Societies/House_Astral_Chorus.md"},"smart_blocks:Houses_Orders_Societies/House_Astral_Chorus.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.01090564,-0.01454212,0.06814278,0.01529619,-0.03416547,0.01845613,0.05031807,-0.01789909,0.02597423,0.00724495,0.0297762,-0.0793444,-0.00066722,0.02328238,0.06782838,0.03230129,-0.01624094,0.06938124,-0.0430811,0.03808433,0.05681593,-0.02381812,0.03417477,-0.0329323,0.03226576,-0.00086215,0.02250582,-0.06627379,-0.04514878,-0.13582538,0.01317043,-0.03436374,0.04032576,-0.02314978,-0.02531558,0.01202469,-0.02916075,0.03288973,-0.06039663,0.04506224,0.0012424,0.00120714,-0.01579608,-0.03034113,0.00464557,-0.04497487,0.00026505,-0.01323328,-0.04727725,0.01225221,-0.05583094,-0.00784013,-0.02703995,0.04682143,-0.03042288,0.03411179,0.09380981,0.00973003,0.05173934,0.00958602,0.02922952,0.00741871,-0.19360113,0.06522162,0.01655966,-0.00244543,-0.03750315,-0.03034897,-0.02631067,0.02280624,-0.00022413,-0.07042802,0.04744334,0.05791598,0.02976136,0.01955315,-0.02956862,-0.08889055,-0.01244752,-0.02435584,-0.03065422,-0.00917359,-0.08070894,-0.05095145,-0.02575373,0.00423119,0.0318028,-0.06218754,-0.01293316,0.01138649,-0.04682116,-0.06727397,-0.02221324,0.06461079,-0.00909628,-0.06092995,-0.04537295,0.00297064,0.03284312,0.13036516,-0.03069022,0.05092511,-0.0226904,0.020927,0.07327757,-0.0604067,-0.03134988,-0.06781768,-0.0284601,0.00321931,0.01806814,0.01116659,0.02